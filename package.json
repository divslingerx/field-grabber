{
  "name": "field-grabber",
  "version": "0.1.0",
  "description": "Declarative field mapper — pick, rename, and transform fields from a source object",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "fields",
    "pick",
    "mapper",
    "transform",
    "rename"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  }
}
